{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend (Bun Built-in Node Debugger)",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "--inspect-wait",
        "src/index.ts"
      ],
      "port": 6499,
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Bun (Port 6499)",
      "port": 6499,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "Debug Backend (Bun Extension)",
      "program": "${workspaceFolder}/src/index.ts",
      "watchMode": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}
